# Copy to backend.hcl and fill in, then: terraform init -backend-config=backend.hcl
# The bucket and dynamodb_table must already exist (see bootstrap/).
bucket         = "my-org-terraform-state-unique-name"
key            = "ecs-dynatrace/terraform.tfstate"
region         = "us-east-1"
dynamodb_table = "terraform-locks"
encrypt        = true
